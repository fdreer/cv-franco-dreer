---
const kv = Astro.locals.runtime?.env?.LIKES_KV
const value = kv ? await kv.get('cv-franco-views') : null
const numberViews = value ? parseInt(value) : 0
---

<div id="views-counter" aria-label="Visualizaciones" title="Visualizaciones">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
    </svg>
    <span id="views-amount">{numberViews}</span>
</div>

<style>
    #views-counter {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 2px solid var(--color-border);
        border-radius: 20px;
        padding: 5px 14px 5px 10px;
        color: var(--color-muted);
        font-size: 0.88rem;
        font-weight: 500;
        user-select: none;
        cursor: default;
    }
    svg {
        width: 18px;
        height: 18px;
        fill: currentColor;
        flex-shrink: 0;
    }
</style>

<script>
    const SESSION_KEY = 'cv-franco-viewed'

    const counter = document.getElementById('views-counter')
    const viewsAmount = document.getElementById('views-amount')

    if (!sessionStorage.getItem(SESSION_KEY)) {
        sessionStorage.setItem(SESSION_KEY, 'true')
        fetch('/api/views', { method: 'POST' })
            .then(() => {
                if (viewsAmount) {
                    viewsAmount.textContent = `${Number(viewsAmount.textContent) + 1}`
                }
            })
            .catch(() => {})
    }
</script>
