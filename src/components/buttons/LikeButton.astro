---
const kv = Astro.locals.runtime?.env?.LIKES_KV
const value = kv ? await kv.get('cv-franco') : null
const numberLikes = value ? parseInt(value) : 0
---

<button id="like-btn" aria-label="Me gusta" title="Me gusta">
    <svg id="thumb-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z"/>
    </svg>
    <span id="likes-amount">{numberLikes}</span>
</button>

<style>
    #like-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: none;
        border: 2px solid var(--color-border);
        border-radius: 20px;
        padding: 5px 14px 5px 10px;
        cursor: pointer;
        color: var(--color-muted);
        transition:
            color 0.2s ease,
            border-color 0.2s ease,
            background 0.2s ease;
        font-size: 0.88rem;
        font-weight: 500;
        user-select: none;
    }
    #like-btn:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: var(--color-accent-light);
    }
    #like-btn.liked {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: var(--color-accent-light);
    }
    svg {
        width: 18px;
        height: 18px;
        fill: currentColor;
    }
    #like-btn.pop svg {
        animation: thumbPop 0.35s cubic-bezier(0.36, 0.07, 0.19, 0.97) forwards;
    }
    @keyframes thumbPop {
        0%   { transform: scale(1) rotate(0deg); }
        25%  { transform: scale(1.5) rotate(-20deg); }
        60%  { transform: scale(0.85) rotate(8deg); }
        100% { transform: scale(1) rotate(0deg); }
    }
</style>

<script>
    import { isLiked, setLike, removeLike } from '@/lib/local-storage'

    const btn = document.getElementById('like-btn') as HTMLButtonElement
    const likesAmount = document.getElementById('likes-amount')

    if (isLiked() === 'true') {
        btn?.classList.add('liked')
    }

    btn?.addEventListener('click', async () => {
        const liked = isLiked()

        btn.classList.remove('pop')
        void btn.offsetWidth // reflow para reiniciar animación
        btn.classList.add('pop')
        setTimeout(() => btn.classList.remove('pop'), 400)

        if (!liked) {
            setLike()
            btn.classList.add('liked')
            if (likesAmount) likesAmount.textContent = `${Number(likesAmount.textContent) + 1}`
            await fetch('/api/likes', { method: 'POST' })
        } else {
            removeLike()
            btn.classList.remove('liked')
            if (likesAmount) likesAmount.textContent = `${Number(likesAmount.textContent) - 1}`
            await fetch('/api/likes', { method: 'PATCH' })
        }
    })
</script>
