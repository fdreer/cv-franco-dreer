---
import { Image } from 'astro:assets'
import heart from '../../../../public/pixel-heart.svg'

interface Props {
	size: 'small' | 'medium' | 'big'
}

const { size } = Astro.props
---

<Image src={heart} alt="Pixel heart" class={size} />

<style>
	.small {
		width: 20px;
		height: 20px;
	}
	.medium {
		font-size: 32px;
	}
	.big {
		font-size: 48px;
	}
</style>
