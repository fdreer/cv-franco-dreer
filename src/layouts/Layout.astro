---
import Footer from '../components/Footer.astro'

interface Props {
	title: string
}

const { title } = Astro.props
const mainColor = 'rgba(17, 24, 39, 1)'
const secondaryColor = 'rgba(167, 139, 250, 1)'
const backgroundColor = '#dcdcdc'
const textColor = '#222'
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="layout">
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
<style
	is:global
	define:vars={{ mainColor, secondaryColor, textColor, backgroundColor }}
>
	:root {
		background-color: var(--backgroundColor);
		color: var(--textColor);
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			Roboto,
			Oxygen,
			Ubuntu,
			Cantarell,
			'Open Sans',
			'Helvetica Neue',
			sans-serif;
	}
	* {
		min-width: 0;
		font: inherit;
		margin: 0;
	}
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}
	html {
		font-family: system-ui, sans-serif;
		font-size: 1.3rem;
		scroll-behavior: smooth;
	}
	a {
		text-decoration: none;
		color: inherit;
	}
	.layout {
		min-height: 100vh;
		margin: 0;
		display: flex;
		flex-direction: column;
	}

	.main-navbar,
	.main-footer {
		height: auto;
	}

	main {
		flex-grow: 1;
		max-width: 710px;
		margin: 0 auto;
		padding: 20px 0;
	}
	h1,
	h2,
	h3,
	h4,
	h5,
	h6 {
		text-wrap: balance;
	}
	p {
		text-wrap: pretty;
	}
	ul {
		padding: 0;
	}
	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}
</style>
