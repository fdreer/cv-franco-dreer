---
import Container from '@/components/ui/Container.astro'
import { Image } from 'astro:assets'
import myFormation from '../../public/data/my-formation.json'
import ucasal from '@/assets/img/ucasal.jpg'
import digitalHouse from '@/assets/img/digital house.jpg'

const logoMap: Record<string, ImageMetadata> = {
	'Universidad Católica de Salta': ucasal,
	'Digital House': digitalHouse,
}
---

<Container>
	<section class="data">
		<h2>Formación</h2>
		<ul>
			{
				myFormation.map(({ title, institution, description, timeFrame }: Formation) => {
					return (
						<li>
							<div class="institution-icon">
							{logoMap[institution]
								? <Image src={logoMap[institution]} alt={institution} width={46} height={46} class="logo-img" />
								: institution[0]
							}
						</div>
							<div class="details">
								<h3 class="degree-title">{title}</h3>
								<span class="institution">{institution}</span>
								{timeFrame && (
									<span class="date">
										{timeFrame.startDate} – {timeFrame.endDate}
									</span>
								)}
								{description && <p class="desc">{description}</p>}
							</div>
						</li>
					)
				})
			}
		</ul>
	</section>
</Container>

<style>
	ul {
		display: flex;
		flex-direction: column;
	}

	li {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		padding: 1.25rem 0;
		border-bottom: 1px solid var(--color-border);
	}

	li:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	li:first-child {
		padding-top: 0;
	}

	.institution-icon {
		width: 46px;
		height: 46px;
		border-radius: 8px;
		background: var(--color-accent-light);
		color: var(--color-primary);
		font-weight: 700;
		font-size: 1.2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		border: 1px solid var(--color-border);
	}

	.details {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.degree-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-primary);
	}

	.institution {
		font-size: 0.9rem;
		color: var(--color-text);
	}

	.date {
		font-size: 0.8rem;
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		font-weight: 500;
		margin-top: 2px;
	}

	.desc {
		font-size: 0.95rem;
		color: var(--color-muted);
		margin-top: 6px;
	}

	.logo-img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		border-radius: 8px;
		padding: 4px;
	}
</style>
