---
import Container from '@/components/ui/Container.astro'
import Square from '@/components/ui/Square.astro'
import Cv from '@/icons/Cv.astro'
import GitHub from '@/icons/GitHub.astro'
import LinkedIn from '@/icons/LinkedIn.astro'
import Mail from '@/icons/Mail.astro'
import MapPin from '@/icons/MapPin.astro'
import { Image } from 'astro:assets'
import myPhoto from '@/assets/foto.jpeg'
---

<Container>
	<section class="info">
		<article class="me">
			<h1>Franco Dreer</h1>
			<h3>
				Estudiante de contador público con orientación al desarrollo de software
			</h3>

			<span><MapPin /> Salta Capital, Argentina</span>
			<footer>
				<Square>
					<a
						class="social-button"
						href="https://www.linkedin.com/in/francodreer"
						target="_blank"
						title="Visitar perfil de Franco Dreer en LinkedIn"
					>
						<LinkedIn />
					</a>
				</Square>
				<Square>
					<button type="button" class="social-button">
						<Mail />
					</button>
				</Square>
				<Square>
					<a
						class="social-button"
						href="https://github.com/fdreer"
						target="_blank"
						title="Visitar perfil de Franco Dreer en GitHub"
					>
						<GitHub />
					</a>
				</Square>
				<Square>
					<a
						class="social-button"
						href="https://drive.google.com/file/d/1tchMOGRJqqcNPyvU24_feBb2jQXgyiUy/view?usp=sharing"
						target="_blank"
						title="Descargar Cv de Franco Dreer"
					>
						<Cv />
					</a>
				</Square>
			</footer>
		</article>
		<article>
			<Image src={myPhoto} alt="Foto 4x4 de Franco Dreer" class="my-photo" />
		</article>
	</section>
</Container>

<script>
	const button = document.querySelector('button.social-button')

	const handleClick = () => {
		navigator.clipboard.writeText('francodreer@gmail.com')
	}

	button?.addEventListener('click', handleClick)
</script>

<style>
	h1 {
		font-size: 2rem;
		font-weight: 500;
	}
	h3 {
		font-size: 1.4rem;
		font-weight: 500;
	}
	span {
		display: flex;
		align-items: end;
		gap: 5px;
	}
	.info {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.me {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	@media (width <= 700px) {
		.info {
			flex-direction: column-reverse;
			gap: 1rem;
		}
		.me {
			align-items: center;
			text-align: center;
		}
	}
	.my-photo {
		border-radius: 10px;
		width: 120px;
		height: 120px;
	}
	footer {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 10px;
	}
	.social-button {
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 5px;
		cursor: pointer;
		border: none;
		background: none;
		color: inherit;
	}
</style>
