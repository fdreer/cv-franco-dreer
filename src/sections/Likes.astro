---
import Container from '@/components/ui/Container.astro'
import LikeButton from '@/components/buttons/LikeButton.astro'
---

<Container>
	<section>
		<article>
			<h3>Likes</h3>
			<LikeButton />
		</article>
	</section>
</Container>

<style>
	section {
		display: flex;
		justify-content: center;
	}
	h3 {
		font-size: 1.5rem;
		font-weight: 500;
	}
	article {
		display: flex;
		flex-direction: column;
		justify-content: center;
		text-align: center;
		align-items: center;
		padding: 5px 20px;
		width: 150px;

		border: var(--color-primary) 1px solid;
		box-shadow: 5px 5px 0px -3px var(--color-primary);
	}
</style>
