---
import Container from '@/components/ui/Container.astro'
import LikeButton from '@/components/buttons/LikeButton.astro'
---

<Container>
	<section>
		<article>
			<h3>Likes</h3>
			<LikeButton />
		</article>
	</section>
</Container>

<style>
	section {
		padding: 30px 0;
		display: flex;
		justify-content: center;
	}
	article {
		display: flex;
		flex-direction: column;
		justify-content: center;
		text-align: center;
		align-items: center;
		padding: 5px 20px;
		width: 150px;

		border-radius: 20px;
		box-shadow: 0px 5px 14px -4px rgba(0, 0, 0, 0.68);
	}
</style>
